# x402 MCP Server — copy to .env and fill in

# Network: base-sepolia (testnet, no real $) | base (mainnet, real USDC)
NETWORK=base-sepolia

# Set to true to enforce x402 payment on all /api/* routes
REQUIRE_PAYMENT=false

# Auto-generated on first run (stored in data/wallet.json)
# Override here if using secrets manager or existing wallet
# WALLET_ADDRESS=0x...
# WALLET_PRIVATE_KEY=0x...

# Service URLs (defaults match local dev setup)
COMFYUI_URL=http://localhost:8188
OLLAMA_URL=http://localhost:11434
LITELLM_URL=http://localhost:4000

# Default model for LLM endpoints
DEFAULT_LLM_MODEL=llama3.1:8b

# Server port
PORT=8402

# x402 facilitator (default: public Coinbase facilitator)
FACILITATOR_URL=https://x402.org/facilitator
